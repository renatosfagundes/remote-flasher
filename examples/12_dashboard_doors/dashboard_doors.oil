// Example 12: Dashboard Doors — interactive doors via VirtualIO + Dashboard
//
// Rate capped at 5 Hz (200 ms) to keep the lab camera alive — see
// README / manual "Serial transmit rate vs. camera".
OIL_VERSION = "2.5" : "dashboard_doors";

CPU test {
  OS config {
    STATUS = STANDARD;
    BUILD = TRUE {
      TRAMPOLINE_BASE_PATH = "../../../";
      APP_NAME = "image";
      APP_SRC = "dashboard_doors.cpp";
      APP_SRC = "DashboardSignals.cpp";
      APP_SRC = "VirtualIO.cpp";
      CPPCOMPILER = "avr-g++";
      COMPILER    = "avr-gcc";
      LINKER      = "avr-gcc";
      ASSEMBLER   = "avr-gcc";
      COPIER      = "avr-objcopy";
      SYSTEM      = PYTHON;
      LIBRARY     = serial;
    };
    SYSTEM_CALL = TRUE;
  };

  APPMODE stdAppmode {};

  ALARM ioAlarm {
    COUNTER = SystemCounter;
    ACTION = ACTIVATETASK { TASK = UpdateIO; };
    AUTOSTART = TRUE {
      ALARMTIME = 200;
      CYCLETIME = 200;
      APPMODE = stdAppmode;
    };
  };

  TASK UpdateIO {
    PRIORITY = 10;
    AUTOSTART = FALSE;
    ACTIVATION = 1;
    SCHEDULE = FULL;
    STACKSIZE = 256;
  };
};
