# Secrets (SSH credentials, IPs) — NEVER commit
secrets.py

# User-specific settings (credentials, folder paths)
.credentials.json
.user_settings.json

# PyInstaller output
dist/
build/

# Version-specific PyInstaller spec files (build artifacts — RemoteFlasher.spec is the source of truth)
RemoteFlasher_v*.spec

# Backup files
*.bak

# Python cache
__pycache__/
*.pyc
third_party/

# Dev scratch — LLM-assisted QML drafts and preview harness, not needed for
# end users. Kept locally but not tracked.
Gemini_help/

# Ad-hoc firmware sketches used only during development/testing.
test_firmwares/
blink.hex
